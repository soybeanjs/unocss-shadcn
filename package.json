{
  "name": "@soybeanjs/unocss-shadcn",
  "version": "0.3.4",
  "description": "unocss preset shadcn for Soybean UI",
  "homepage": "https://github.com/soybeanjs/unocss-shadcn",
  "bugs": {
    "url": "https://github.com/soybeanjs/unocss-shadcn/issues"
  },
  "license": "MIT",
  "author": {
    "name": "Soybean",
    "email": "soybeanjs@outlook.com",
    "url": "https://github.com/soybeanjs"
  },
  "repository": {
    "url": "https://github.com/soybeanjs/unocss-shadcn.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    }
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "tsdown",
    "cleanup": "soy cleanup",
    "commit": "soy git-commit",
    "dev": "tsdown",
    "fmt": "oxfmt",
    "lint": "oxlint . --fix",
    "prepare": "simple-git-hooks",
    "publish-pkg": "pnpm publish --access public",
    "release": "soy release",
    "typecheck": "tsc --noEmit --skipLibCheck",
    "update-pkg": "soy ncu"
  },
  "dependencies": {
    "unocss": "^66.6.8"
  },
  "devDependencies": {
    "@soybeanjs/cli": "1.7.1",
    "@types/node": "25.6.0",
    "lint-staged": "16.4.0",
    "oxfmt": "^0.46.0",
    "oxlint": "^1.61.0",
    "simple-git-hooks": "2.13.1",
    "tsdown": "0.21.10",
    "tsx": "4.21.0",
    "typescript": "6.0.3"
  },
  "simple-git-hooks": {
    "commit-msg": "pnpm soy git-commit-verify",
    "pre-commit": "pnpm typecheck && pnpm lint-staged"
  },
  "lint-staged": {
    "*": "oxlint . --fix && oxfmt"
  },
  "packageManager": "pnpm@10.33.2"
}
